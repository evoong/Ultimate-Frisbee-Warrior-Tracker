{
  "name": "ultimate-frisbee-warrior-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run frontend\"",
    "server": "node --dns-result-order=ipv4first node_modules/.bin/tsx server/index.ts",
    "frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "npm run server",
    "deploy": "npm run build && wrangler deploy --config wrangler.jsonc",
    "deploy:dev": "npm run build && wrangler deploy --config wrangler.jsonc --env development",
    "deploy:vercel": "npx vercel --prod --yes",
    "test": "node server.test.mjs"
  },
  "retool": {
    "app": {
      "uuid": "ca115e50-71fc-11f1-8c19-0b2bb978852c"
    }
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@supabase/server": "^1.2.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/multer": "^2.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jose": "^6.2.3",
    "multer": "^2.2.0",
    "pg": "^8.11.3",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.10.9",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "wrangler": "^3.82.0"
  }
}
